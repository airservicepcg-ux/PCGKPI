<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Create Work Order</title>

<style>

body{
font-family: Arial, sans-serif;
background:#eef1f5;
margin:0;
padding:30px;
}

.container{
max-width:500px;
margin:auto;
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

h2{
text-align:center;
}

label{
margin-top:10px;
display:block;
}

input,select,button{
width:100%;
padding:10px;
margin-top:8px;
border-radius:6px;
border:1px solid #ccc;
}

button{
background:#3a66a8;
color:white;
border:none;
cursor:pointer;
font-size:16px;
}

button:hover{
background:#2c4f82;
}

</style>

</head>

<body>

<div class="container">

<h2>Create Work Order</h2>

<label>Search Asset</label>

<select id="assetList">
<option>Loading...</option>
</select>

<label>Problem</label>
<input type="text" id="problem" placeholder="Describe problem">

<button onclick="submitWO()">Submit</button>

</div>

<script>

const apiURL = "PUT_GAS_URL_HERE";

async function loadAssets(){

let res = await fetch(apiURL);
let data = await res.json();

let dropdown = document.getElementById("assetList");

dropdown.innerHTML="";

data.forEach(a => {

let option = document.createElement("option");

option.value = a.assetID;
option.text = a.assetID + " - " + a.assetName;

dropdown.appendChild(option);

});

}

function submitWO(){

let asset = document.getElementById("assetList").value;
let problem = document.getElementById("problem").value;

alert("Submit Work Order\nAsset: "+asset+"\nProblem: "+problem);

}

loadAssets();

</script>

</body>
</html>
